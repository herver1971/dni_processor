# ============================================================
# DNI Processor — Configuración de entorno
# ============================================================
#
# Copiá este archivo a `.env` en la raíz del proyecto y ajustá los
# valores. El servicio lo lee automáticamente al arrancar via
# pydantic-settings.
#
# Todos los valores tienen defaults razonables; sólo necesitás
# overridear lo que querés cambiar.
# ============================================================


# ============================================================
# Server
# ============================================================

# Host de bind. En producción detrás de Tailscale, mantener en 127.0.0.1:
# la app NO debe ser accesible directamente desde la red local sin pasar
# por Tailscale. La interfaz tailscale0 puede alcanzar 127.0.0.1 sin
# problema porque ambas están en el mismo host.
DNI_HOST=127.0.0.1

# Puerto. Cambiar si choca con otro servicio (por ejemplo Escriba).
DNI_PORT=8001


# ============================================================
# Storage
# ============================================================

# Directorio raíz para datos persistentes (sesiones). Debe existir y
# ser escribible por el user que corre el servicio.
# En producción típicamente: /home/hernan/dni_processor/data
DNI_DATA_DIR=./data

# Subdir para sesiones. Si se omite, se calcula como DATA_DIR/sessions.
# DNI_SESSIONS_DIR=

# Cache de modelos de visión (detector de caras). EasyOCR usa su propio
# cache interno en ~/.EasyOCR/model (no configurable desde acá).
# DNI_MODEL_CACHE_DIR=~/.cache/dni_processor


# ============================================================
# Behavior
# ============================================================

# Nivel de logging. INFO en producción, DEBUG para troubleshooting.
DNI_LOG_LEVEL=INFO

# Habilita / deshabilita el paso de OCR en el matcheo. Si está en false,
# las sugerencias se generan sólo por orden de upload (sin OCR del DNI).
DNI_RUN_OCR=true


# ============================================================
# Hardening (Sprint 4a)
# ============================================================

# Cuando es true, los templates emiten `data-debug="true"` en el <html>.
# Los scripts del frontend leen ese atributo para activar console.log
# diagnósticos. DEJAR EN false EN PRODUCCIÓN.
DNI_DEBUG=false

# Habilita slowapi sobre los endpoints "caros". En producción mantener
# en true. Sólo se desactiva en tests (vía monkeypatch) para que
# invocaciones consecutivas del mismo endpoint no gatillen 429.
DNI_RATE_LIMIT_ENABLED=true
